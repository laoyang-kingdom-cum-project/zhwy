<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BloodSugarMapper">
    
    <resultMap type="BloodSugar" id="BloodSugarResult">
        <result property="id"    column="id"    />
        <result property="datetime"    column="datetime"    />
        <result property="value"    column="value"    />
        <result property="userid"    column="userid"    />
    </resultMap>

    <sql id="selectBloodSugarVo">
        select id, datetime, value, userid from blood_sugar
    </sql>

    <select id="selectBloodSugarList" parameterType="BloodSugar" resultMap="BloodSugarResult">
        <include refid="selectBloodSugarVo"/>
        <where>  
            <if test="id != null "> and id = #{id}</if>
            <if test="params.beginDatetime != null and params.beginDatetime != '' and params.endDatetime != null and params.endDatetime != ''"> and datetime between #{params.beginDatetime} and #{params.endDatetime}</if>
            <if test="value != null  and value != ''"> and value = #{value}</if>
            <if test="userid != null "> and userid = #{userid}</if>
        </where>
    </select>
    
    <select id="selectBloodSugarById" parameterType="Long" resultMap="BloodSugarResult">
        <include refid="selectBloodSugarVo"/>
        where id = #{id}
    </select>

    <insert id="insertBloodSugar" parameterType="BloodSugar" useGeneratedKeys="true" keyProperty="id">
        insert into blood_sugar
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="datetime != null">datetime,</if>
            <if test="value != null">value,</if>
            <if test="userid != null">userid,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="datetime != null">#{datetime},</if>
            <if test="value != null">#{value},</if>
            <if test="userid != null">#{userid},</if>
         </trim>
    </insert>

    <update id="updateBloodSugar" parameterType="BloodSugar">
        update blood_sugar
        <trim prefix="SET" suffixOverrides=",">
            <if test="datetime != null">datetime = #{datetime},</if>
            <if test="value != null">value = #{value},</if>
            <if test="userid != null">userid = #{userid},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteBloodSugarById" parameterType="Long">
        delete from blood_sugar where id = #{id}
    </delete>

    <delete id="deleteBloodSugarByIds" parameterType="String">
        delete from blood_sugar where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>