<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.CaptchaMapper">
    
    <resultMap type="Captcha" id="CaptchaResult">
        <result property="id"    column="id"    />
        <result property="target"    column="target"    />
        <result property="code"    column="code"    />
        <result property="expireAt"    column="expire_at"    />
    </resultMap>

    <sql id="selectCaptchaVo">
        select id, target, code, expire_at from captcha
    </sql>

    <select id="selectCaptchaList" parameterType="Captcha" resultMap="CaptchaResult">
        <include refid="selectCaptchaVo"/>
        <where>  
            <if test="target != null  and target != ''"> and target = #{target}</if>
            <if test="code != null  and code != ''"> and code = #{code}</if>
            <if test="expireAt != null "> and expire_at = #{expireAt}</if>
        </where>
    </select>
    
    <select id="selectCaptchaById" parameterType="Long" resultMap="CaptchaResult">
        <include refid="selectCaptchaVo"/>
        where id = #{id}
    </select>

    <insert id="insertCaptcha" parameterType="Captcha" useGeneratedKeys="true" keyProperty="id">
        insert into captcha
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="target != null and target != ''">target,</if>
            <if test="code != null and code != ''">code,</if>
            <if test="expireAt != null">expire_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="target != null and target != ''">#{target},</if>
            <if test="code != null and code != ''">#{code},</if>
            <if test="expireAt != null">#{expireAt},</if>
         </trim>
    </insert>

    <update id="updateCaptcha" parameterType="Captcha">
        update captcha
        <trim prefix="SET" suffixOverrides=",">
            <if test="target != null and target != ''">target = #{target},</if>
            <if test="code != null and code != ''">code = #{code},</if>
            <if test="expireAt != null">expire_at = #{expireAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteCaptchaById" parameterType="Long">
        delete from captcha where id = #{id}
    </delete>

    <delete id="deleteCaptchaByIds" parameterType="String">
        delete from captcha where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>