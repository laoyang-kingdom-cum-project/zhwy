<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.PaymentBillMapper">
    
    <resultMap type="PaymentBill" id="PaymentBillResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="billNo"    column="bill_no"    />
        <result property="billName"    column="bill_name"    />
        <result property="billType"    column="bill_type"    />
        <result property="amount"    column="amount"    />
        <result property="status"    column="status"    />
        <result property="payTime"    column="pay_time"    />
        <result property="payMethod"    column="pay_method"    />
        <result property="billPeriod"    column="bill_period"    />
        <result property="dueDate"    column="due_date"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectPaymentBillVo">
        select id, user_id, bill_no, bill_name, bill_type, amount, status, pay_time, pay_method, bill_period, due_date, remark, create_time, update_time, del_flag from payment_bill
    </sql>

    <select id="selectPaymentBillList" parameterType="PaymentBill" resultMap="PaymentBillResult">
        <include refid="selectPaymentBillVo"/>
        <where>  
            <if test="id != null "> and id = #{id}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="billNo != null  and billNo != ''"> and bill_no = #{billNo}</if>
            <if test="billName != null  and billName != ''"> and bill_name like concat('%', #{billName}, '%')</if>
            <if test="billType != null  and billType != ''"> and bill_type = #{billType}</if>
            <if test="amount != null "> and amount = #{amount}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="payTime != null "> and pay_time = #{payTime}</if>
            <if test="payMethod != null  and payMethod != ''"> and pay_method = #{payMethod}</if>
            <if test="billPeriod != null  and billPeriod != ''"> and bill_period = #{billPeriod}</if>
            <if test="dueDate != null "> and due_date = #{dueDate}</if>
        </where>
    </select>
    
    <select id="selectPaymentBillById" parameterType="Long" resultMap="PaymentBillResult">
        <include refid="selectPaymentBillVo"/>
        where id = #{id}
    </select>

    <insert id="insertPaymentBill" parameterType="PaymentBill" useGeneratedKeys="true" keyProperty="id">
        insert into payment_bill
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="billNo != null and billNo != ''">bill_no,</if>
            <if test="billName != null and billName != ''">bill_name,</if>
            <if test="billType != null and billType != ''">bill_type,</if>
            <if test="amount != null">amount,</if>
            <if test="status != null">status,</if>
            <if test="payTime != null">pay_time,</if>
            <if test="payMethod != null">pay_method,</if>
            <if test="billPeriod != null">bill_period,</if>
            <if test="dueDate != null">due_date,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="billNo != null and billNo != ''">#{billNo},</if>
            <if test="billName != null and billName != ''">#{billName},</if>
            <if test="billType != null and billType != ''">#{billType},</if>
            <if test="amount != null">#{amount},</if>
            <if test="status != null">#{status},</if>
            <if test="payTime != null">#{payTime},</if>
            <if test="payMethod != null">#{payMethod},</if>
            <if test="billPeriod != null">#{billPeriod},</if>
            <if test="dueDate != null">#{dueDate},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updatePaymentBill" parameterType="PaymentBill">
        update payment_bill
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="billNo != null and billNo != ''">bill_no = #{billNo},</if>
            <if test="billName != null and billName != ''">bill_name = #{billName},</if>
            <if test="billType != null and billType != ''">bill_type = #{billType},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="payTime != null">pay_time = #{payTime},</if>
            <if test="payMethod != null">pay_method = #{payMethod},</if>
            <if test="billPeriod != null">bill_period = #{billPeriod},</if>
            <if test="dueDate != null">due_date = #{dueDate},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePaymentBillById" parameterType="Long">
        delete from payment_bill where id = #{id}
    </delete>

    <delete id="deletePaymentBillByIds" parameterType="String">
        delete from payment_bill where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>