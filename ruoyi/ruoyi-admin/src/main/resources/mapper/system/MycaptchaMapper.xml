<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.MycaptchaMapper">
    
    <resultMap type="Mycaptcha" id="MycaptchaResult">
        <result property="id"    column="id"    />
        <result property="target"    column="target"    />
        <result property="code"    column="code"    />
        <result property="expireAt"    column="expire_at"    />
    </resultMap>

    <sql id="selectMycaptchaVo">
        select id, target, code, expire_at from mycaptcha
    </sql>

    <select id="selectMycaptchaList" parameterType="Mycaptcha" resultMap="MycaptchaResult">
        <include refid="selectMycaptchaVo"/>
        <where>  
            <if test="target != null  and target != ''"> and target = #{target}</if>
            <if test="code != null  and code != ''"> and code = #{code}</if>
            <if test="expireAt != null "> and expire_at = #{expireAt}</if>
        </where>
    </select>
    
    <select id="selectMycaptchaById" parameterType="Long" resultMap="MycaptchaResult">
        <include refid="selectMycaptchaVo"/>
        where id = #{id}
    </select>

    <insert id="insertMycaptcha" parameterType="Mycaptcha" useGeneratedKeys="true" keyProperty="id">
        insert into mycaptcha
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="target != null and target != ''">target,</if>
            <if test="code != null and code != ''">code,</if>
            <if test="expireAt != null">expire_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="target != null and target != ''">#{target},</if>
            <if test="code != null and code != ''">#{code},</if>
            <if test="expireAt != null">#{expireAt},</if>
         </trim>
    </insert>

    <update id="updateMycaptcha" parameterType="Mycaptcha">
        update mycaptcha
        <trim prefix="SET" suffixOverrides=",">
            <if test="target != null and target != ''">target = #{target},</if>
            <if test="code != null and code != ''">code = #{code},</if>
            <if test="expireAt != null">expire_at = #{expireAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteMycaptchaById" parameterType="Long">
        delete from mycaptcha where id = #{id}
    </delete>

    <delete id="deleteMycaptchaByIds" parameterType="String">
        delete from mycaptcha where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>