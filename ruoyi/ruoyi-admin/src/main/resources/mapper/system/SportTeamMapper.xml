<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SportTeamMapper">
    
    <resultMap type="SportTeam" id="SportTeamResult">
        <result property="id"    column="id"    />
        <result property="avatar"    column="avatar"    />
        <result property="content"    column="content"    />
        <result property="teamName"    column="team_name"    />
        <result property="memberCount"    column="member_count"    />
        <result property="category"    column="category"    />
        <result property="createdAt"    column="created_at"    />
        <result property="updatedAt"    column="updated_at"    />
        <result property="lowerCamelase"    column="lowerCamelase"    />
        <result property="toralSportsTime"    column="toralSportsTime"    />
        <result property="totalConsumption"    column="totalConsumption"    />
        <result property="tasKTime"    column="tasKTime"    />
        <result property="taskday"    column="taskday"    />
    </resultMap>

    <sql id="selectSportTeamVo">
        select id, avatar, content, team_name, member_count, category, created_at, updated_at, lowerCamelase, toralSportsTime, totalConsumption, tasKTime, taskday from sport_team
    </sql>

    <select id="selectSportTeamList" parameterType="SportTeam" resultMap="SportTeamResult">
        <include refid="selectSportTeamVo"/>
        <where>  
            <if test="id != null "> and id = #{id}</if>
            <if test="avatar != null  and avatar != ''"> and avatar = #{avatar}</if>
            <if test="content != null  and content != ''"> and content = #{content}</if>
            <if test="teamName != null  and teamName != ''"> and team_name like concat('%', #{teamName}, '%')</if>
            <if test="params.beginMemberCount != null and params.beginMemberCount != '' and params.endMemberCount != null and params.endMemberCount != ''"> and member_count between #{params.beginMemberCount} and #{params.endMemberCount}</if>
            <if test="category != null  and category != ''"> and category = #{category}</if>
            <if test="params.beginCreatedAt != null and params.beginCreatedAt != '' and params.endCreatedAt != null and params.endCreatedAt != ''"> and created_at between #{params.beginCreatedAt} and #{params.endCreatedAt}</if>
            <if test="params.beginUpdatedAt != null and params.beginUpdatedAt != '' and params.endUpdatedAt != null and params.endUpdatedAt != ''"> and updated_at between #{params.beginUpdatedAt} and #{params.endUpdatedAt}</if>
            <if test="lowerCamelase != null  and lowerCamelase != ''"> and lowerCamelase = #{lowerCamelase}</if>
            <if test="toralSportsTime != null  and toralSportsTime != ''"> and toralSportsTime = #{toralSportsTime}</if>
            <if test="totalConsumption != null  and totalConsumption != ''"> and totalConsumption = #{totalConsumption}</if>
            <if test="tasKTime != null "> and tasKTime = #{tasKTime}</if>
            <if test="taskday != null  and taskday != ''"> and taskday = #{taskday}</if>
        </where>
    </select>
    
    <select id="selectSportTeamById" parameterType="Long" resultMap="SportTeamResult">
        <include refid="selectSportTeamVo"/>
        where id = #{id}
    </select>

    <insert id="insertSportTeam" parameterType="SportTeam" useGeneratedKeys="true" keyProperty="id">
        insert into sport_team
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="avatar != null and avatar != ''">avatar,</if>
            <if test="content != null">content,</if>
            <if test="teamName != null and teamName != ''">team_name,</if>
            <if test="memberCount != null and memberCount != ''">member_count,</if>
            <if test="category != null and category != ''">category,</if>
            <if test="createdAt != null">created_at,</if>
            <if test="updatedAt != null">updated_at,</if>
            <if test="lowerCamelase != null">lowerCamelase,</if>
            <if test="toralSportsTime != null">toralSportsTime,</if>
            <if test="totalConsumption != null">totalConsumption,</if>
            <if test="tasKTime != null">tasKTime,</if>
            <if test="taskday != null">taskday,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="avatar != null and avatar != ''">#{avatar},</if>
            <if test="content != null">#{content},</if>
            <if test="teamName != null and teamName != ''">#{teamName},</if>
            <if test="memberCount != null and memberCount != ''">#{memberCount},</if>
            <if test="category != null and category != ''">#{category},</if>
            <if test="createdAt != null">#{createdAt},</if>
            <if test="updatedAt != null">#{updatedAt},</if>
            <if test="lowerCamelase != null">#{lowerCamelase},</if>
            <if test="toralSportsTime != null">#{toralSportsTime},</if>
            <if test="totalConsumption != null">#{totalConsumption},</if>
            <if test="tasKTime != null">#{tasKTime},</if>
            <if test="taskday != null">#{taskday},</if>
         </trim>
    </insert>

    <update id="updateSportTeam" parameterType="SportTeam">
        update sport_team
        <trim prefix="SET" suffixOverrides=",">
            <if test="avatar != null and avatar != ''">avatar = #{avatar},</if>
            <if test="content != null">content = #{content},</if>
            <if test="teamName != null and teamName != ''">team_name = #{teamName},</if>
            <if test="memberCount != null and memberCount != ''">member_count = #{memberCount},</if>
            <if test="category != null and category != ''">category = #{category},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
            <if test="lowerCamelase != null">lowerCamelase = #{lowerCamelase},</if>
            <if test="toralSportsTime != null">toralSportsTime = #{toralSportsTime},</if>
            <if test="totalConsumption != null">totalConsumption = #{totalConsumption},</if>
            <if test="tasKTime != null">tasKTime = #{tasKTime},</if>
            <if test="taskday != null">taskday = #{taskday},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSportTeamById" parameterType="Long">
        delete from sport_team where id = #{id}
    </delete>

    <delete id="deleteSportTeamByIds" parameterType="String">
        delete from sport_team where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>