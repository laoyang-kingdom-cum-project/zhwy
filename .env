# ---- 应用基础 ----
APP_TITLE=银铃助手
APP_ENV=development

# ---- 后端 ----
API_HOST=localhost
API_PORT=8080
API_PREFIX=/por-api
API_URL=http://localhost:8080

# ---- 前端 Admin UI ----
FRONTEND_PORT=80

# ---- 数据库 ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lyfp
DB_USER=root
DB_PASS=root

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0

# ---- Token (JWT) ----
TOKEN_SECRET=abcdefghijklmnopqrstuvwxyz
