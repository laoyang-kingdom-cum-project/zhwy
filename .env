# ---- 文件上传 ----
UPLOAD_PATH=D:/ruoyi/uploadPath

# ---- Swagger ----
SWAGGER_ENABLED=true

# ---- Druid 监控 ----
DRUID_USER=ruoyi
DRUID_PASS=123456

# ---- 验证码 ----
CAPTCHA_TYPE=math

